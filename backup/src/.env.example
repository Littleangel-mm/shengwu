APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=true
APP_SECRET=change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=720
ALLOW_ACTOR_HEADER=true

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=research_app
DB_PASSWORD=change-me
DB_NAME=research_platform
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

STORAGE_ROOT=data
MAX_UPLOAD_SIZE_MB=200
ALLOWED_EXTENSIONS=pdf,docx,txt,md,xlsx,xls,zip
ZIP_MAX_ENTRIES=500
ZIP_MAX_UNCOMPRESSED_MB=1000
ZIP_MAX_COMPRESSION_RATIO=100
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
WORKER_POLL_SECONDS=2
WORKER_BATCH_SIZE=1
OCR_ENABLED=true
OCR_PYTHON=.venv-ocr/Scripts/python.exe
OCR_DETECTION_MODEL_NAME=PP-OCRv5_mobile_det
OCR_RECOGNITION_MODEL_NAME=PP-OCRv5_mobile_rec
OCR_DETECTION_MODEL_DIR=models/paddleocr/PP-OCRv5_mobile_det
OCR_RECOGNITION_MODEL_DIR=models/paddleocr/PP-OCRv5_mobile_rec
OCR_DPI=200
OCR_MIN_CONFIDENCE=0.5
OCR_TIMEOUT_SECONDS=1800
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
